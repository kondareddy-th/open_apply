# ── Nexus — AI Career Automation ──────────────────────────────
# Copy this file to .env and fill in your values.
# Most settings have sensible defaults — you only NEED an API key.

# ── Database ──────────────────────────────────────────────────
# Default: SQLite (zero config, works immediately)
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/nexus
DATABASE_URL=sqlite+aiosqlite:///./nexus.db

# ── LLM Provider (REQUIRED — pick one) ───────────────────────
# "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Gmail (optional — for email outreach) ─────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:5175/api/auth/gmail/callback

# ── Deployment ────────────────────────────────────────────────
# Leave empty for standalone. Set for nested deployment:
# BASE_PATH=/apps/nexus
# CORS_ORIGINS=https://yourdomain.com,http://localhost:5175
